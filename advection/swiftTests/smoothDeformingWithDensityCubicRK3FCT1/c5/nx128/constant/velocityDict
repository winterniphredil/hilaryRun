FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      velocityDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

timeVaryingWind true;
type deformationalNonDivergent;
domainSize (1000 1000 0);
endTime    100;
backgroundFlow (10 10 0);