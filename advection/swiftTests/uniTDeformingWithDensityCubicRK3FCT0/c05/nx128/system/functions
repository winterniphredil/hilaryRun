FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      functions;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

#includeFunc multiScalarRKTransport
(
    nFields=2,
    fields=(rho T),
    FCTiters=(0 0),
    FCTlimits=(() ()),
    advectingFlux=phiv,
    massFlux=phi,
    RK_ButcherCoeffs=RK_ButcherCoeffs=3 3((1 0 0) (0.25 0.25 0)                        (0.16666666667 0.16666666667 0.66666666666)),
    gammaCoeffs=(CCRIT CGRAD),
    correctionScheme=cubicUpwind,
    velocityFieldDict=velocityDict
)

minMax
{
    type coded;
    // Load the library containing the 'coded' functionObject
    libs            ("libutilityFunctionObjects.so" "libfiniteVolumeAtmosFOAM.so");

    codeInclude
    #{
        #include "volFields.H"
    #};

    codeExecute
    #{
        const volScalarField& rho
        (
            mesh().lookupObject<volScalarField>("rho")
        );
        const volScalarField& T
        (
            mesh().lookupObject<volScalarField>("T")
        );

        Info << "rho goes from = " << min(rho).value() << " to 1 + "
             << max(rho).value()-1 << endl;
        Info << "T goes from = " << min(T).value() << " to 1 + "
             << max(T).value()-1 << endl;
    #};
}

